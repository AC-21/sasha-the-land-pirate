{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/wasteland-game/scenario-definition.schema.json",
  "title": "Immutable scenario definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "revision",
    "kind",
    "title",
    "purpose",
    "applies_to_packets",
    "fixture",
    "counts",
    "parameters",
    "oracles"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "pattern": "^SCN_[A-Z0-9_]+$" },
    "revision": { "type": "integer", "minimum": 1 },
    "kind": { "enum": ["performance", "save", "migration", "rollback", "gameplay", "aggregate"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "purpose": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "applies_to_packets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^WP-[0-9]{4}$" }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "world_seed",
        "starting_tick",
        "tick_rate_hz",
        "warmup_ticks",
        "duration_ticks",
        "warmup_seconds",
        "duration_seconds",
        "starting_state_id",
        "content_set_id",
        "input_script_id",
        "fixture_manifest"
      ],
      "properties": {
        "world_seed": { "type": "string", "pattern": "^[0-9]+$" },
        "starting_tick": { "type": "string", "pattern": "^[0-9]+$" },
        "tick_rate_hz": { "type": "integer", "minimum": 1, "maximum": 120 },
        "warmup_ticks": { "type": "integer", "minimum": 0 },
        "duration_ticks": { "type": "integer", "minimum": 0 },
        "warmup_seconds": { "type": "integer", "minimum": 0 },
        "duration_seconds": { "type": "integer", "minimum": 0 },
        "starting_state_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
        "content_set_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
        "input_script_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
        "fixture_manifest": { "$ref": "#/$defs/fixtureManifestReference" }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "entities", "objects", "lights", "crowd", "inputs"],
      "properties": {
        "state": { "$ref": "#/$defs/stateCounts" },
        "entities": { "$ref": "#/$defs/entityCounts" },
        "objects": { "$ref": "#/$defs/objectCounts" },
        "lights": { "$ref": "#/$defs/lightCounts" },
        "crowd": { "$ref": "#/$defs/crowdCounts" },
        "inputs": { "$ref": "#/$defs/inputCounts" }
      }
    },
    "parameters": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/parameter" }
    },
    "oracles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/oracle" }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "count": { "type": "integer", "minimum": 0 },
    "stateCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authoritative_records", "save_sections", "content_definitions", "transactions", "save_generations"],
      "properties": {
        "authoritative_records": { "$ref": "#/$defs/count" },
        "save_sections": { "$ref": "#/$defs/count" },
        "content_definitions": { "$ref": "#/$defs/count" },
        "transactions": { "$ref": "#/$defs/count" },
        "save_generations": { "$ref": "#/$defs/count" }
      }
    },
    "entityCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "settlements", "buildings", "households", "specialists", "robots", "vehicles", "factions", "crises", "expeditions"],
      "properties": {
        "total": { "$ref": "#/$defs/count" },
        "settlements": { "$ref": "#/$defs/count" },
        "buildings": { "$ref": "#/$defs/count" },
        "households": { "$ref": "#/$defs/count" },
        "specialists": { "$ref": "#/$defs/count" },
        "robots": { "$ref": "#/$defs/count" },
        "vehicles": { "$ref": "#/$defs/count" },
        "factions": { "$ref": "#/$defs/count" },
        "crises": { "$ref": "#/$defs/count" },
        "expeditions": { "$ref": "#/$defs/count" }
      }
    },
    "fixtureManifestReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^scenarios/fixtures/SCN_[A-Z0-9_]+/r[1-9][0-9]*\\.fixture\\.json$"
        },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "objectCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["placed_total", "dynamic", "static", "lod0", "lod1", "lod2"],
      "properties": {
        "placed_total": { "$ref": "#/$defs/count" },
        "dynamic": { "$ref": "#/$defs/count" },
        "static": { "$ref": "#/$defs/count" },
        "lod0": { "$ref": "#/$defs/count" },
        "lod1": { "$ref": "#/$defs/count" },
        "lod2": { "$ref": "#/$defs/count" }
      }
    },
    "lightCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "directional", "point", "spot", "shadowed"],
      "properties": {
        "total": { "$ref": "#/$defs/count" },
        "directional": { "$ref": "#/$defs/count" },
        "point": { "$ref": "#/$defs/count" },
        "spot": { "$ref": "#/$defs/count" },
        "shadowed": { "$ref": "#/$defs/count" }
      }
    },
    "crowdCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authoritative_people", "visible_agents", "offscreen_people"],
      "properties": {
        "authoritative_people": { "$ref": "#/$defs/count" },
        "visible_agents": { "$ref": "#/$defs/count" },
        "offscreen_people": { "$ref": "#/$defs/count" }
      }
    },
    "inputCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scripted_commands", "keyboard_events", "controller_events", "pointer_events", "fault_injections"],
      "properties": {
        "scripted_commands": { "$ref": "#/$defs/count" },
        "keyboard_events": { "$ref": "#/$defs/count" },
        "controller_events": { "$ref": "#/$defs/count" },
        "pointer_events": { "$ref": "#/$defs/count" },
        "fault_injections": { "$ref": "#/$defs/count" }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "unit"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$" },
        "value": { "type": ["string", "number", "integer", "boolean"] },
        "unit": { "type": ["string", "null"], "maxLength": 64 }
      }
    },
    "oracle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "subject", "operator", "expected", "unit"],
      "properties": {
        "id": { "type": "string", "pattern": "^ORC_[A-Z0-9_]+$" },
        "subject": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$" },
        "operator": { "enum": ["equal", "less-than", "less-or-equal", "greater-or-equal", "matches-reference"] },
        "expected": { "type": ["string", "number", "integer", "boolean"] },
        "unit": { "type": ["string", "null"], "maxLength": 64 }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "counts", "parameters", "oracles"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "entities", "objects", "lights", "crowd", "inputs"],
          "properties": {
            "state": { "$ref": "#/$defs/stateCounts" },
            "entities": { "$ref": "#/$defs/entityCounts" },
            "objects": { "$ref": "#/$defs/objectCounts" },
            "lights": { "$ref": "#/$defs/lightCounts" },
            "crowd": { "$ref": "#/$defs/crowdCounts" },
            "inputs": { "$ref": "#/$defs/inputCounts" }
          }
        },
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/parameter" } },
        "oracles": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/oracle" } }
      }
    }
  }
}

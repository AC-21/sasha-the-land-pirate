{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/wasteland-game/wp0002-local-operator-successor-transaction-evidence.schema.json",
  "title": "WP-0002 delegated local Unity operator successor transaction evidence",
  "oneOf": [
    { "$ref": "#/$defs/authority" },
    { "$ref": "#/$defs/pre-merge" },
    { "$ref": "#/$defs/complete" }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git-sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["login", "id", "type", "author_association"],
      "properties": {
        "login": { "const": "AC-21" },
        "id": { "type": "integer", "minimum": 1 },
        "type": { "const": "User" },
        "author_association": { "const": "OWNER" }
      }
    },
    "comment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "node_id", "api_url", "html_url", "issue_url", "actor",
        "created_at", "updated_at", "body_utf8_sha256"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "node_id": { "type": "string", "minLength": 1 },
        "api_url": { "type": "string", "pattern": "^https://api\\.github\\.com/repos/AC-21/sasha-the-land-pirate/issues/comments/[0-9]+$" },
        "html_url": { "type": "string", "pattern": "^https://github\\.com/AC-21/sasha-the-land-pirate/(pull|issues)/[0-9]+#issuecomment-[0-9]+$" },
        "issue_url": { "type": "string", "pattern": "^https://api\\.github\\.com/repos/AC-21/sasha-the-land-pirate/issues/[0-9]+$" },
        "actor": { "$ref": "#/$defs/actor" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "updated_at": { "$ref": "#/$defs/timestamp" },
        "body_utf8_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "changed-file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path", "status", "old_mode", "new_mode", "old_oid", "new_oid",
        "new_blob_sha256"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "status": { "enum": ["A", "M"] },
        "old_mode": { "pattern": "^[0-7]{6}$" },
        "new_mode": { "const": "100644" },
        "old_oid": { "$ref": "#/$defs/git-sha" },
        "new_oid": { "$ref": "#/$defs/git-sha" },
        "new_blob_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "artifact-ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "byte_size"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "byte_size": { "type": "integer", "minimum": 0 }
      }
    },
    "protection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_at", "main_sha", "strict", "required_checks", "enforce_admins",
        "pull_request_required", "dismiss_stale_reviews", "conversation_resolution",
        "linear_history", "bypass_allowances_empty", "rulesets_empty",
        "push_restrictions_empty", "force_push_disabled", "deletion_disabled",
        "squash_only", "raw_response_sha256", "raw_sha256"
      ],
      "properties": {
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "main_sha": { "$ref": "#/$defs/git-sha" },
        "strict": { "const": true },
        "required_checks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["context", "app_id"],
            "properties": {
              "context": { "enum": ["validate", "wp0002-core", "wp0002-policy"] },
              "app_id": { "const": 15368 }
            }
          }
        },
        "enforce_admins": { "const": true },
        "pull_request_required": { "const": true },
        "dismiss_stale_reviews": { "const": false },
        "conversation_resolution": { "const": true },
        "linear_history": { "const": true },
        "bypass_allowances_empty": { "const": true },
        "rulesets_empty": { "const": true },
        "push_restrictions_empty": { "const": true },
        "force_push_disabled": { "const": true },
        "deletion_disabled": { "const": true },
        "squash_only": { "const": true },
        "raw_response_sha256": {
          "type": "object",
          "additionalProperties": false,
          "required": ["branch", "protection", "repository", "rulesets"],
          "properties": {
            "branch": { "$ref": "#/$defs/sha256" },
            "protection": { "$ref": "#/$defs/sha256" },
            "repository": { "$ref": "#/$defs/sha256" },
            "rulesets": { "$ref": "#/$defs/sha256" }
          }
        },
        "raw_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "base-fields": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "transaction_id", "phase", "repository"],
      "properties": {
        "schema_version": { "const": 1 },
        "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718" },
        "phase": { "enum": ["authority", "pre-merge", "complete"] },
        "repository": {
          "type": "object",
          "additionalProperties": false,
          "required": ["full_name", "id", "owner_login", "owner_id"],
          "properties": {
            "full_name": { "const": "AC-21/sasha-the-land-pirate" },
            "id": { "type": "integer", "minimum": 1 },
            "owner_login": { "const": "AC-21" },
            "owner_id": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "transaction_id", "phase", "repository", "pull_request",
        "authorization_comment", "stage1", "parsed_binding", "raw_artifacts"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718" },
        "phase": { "const": "authority" },
        "repository": { "$ref": "#/$defs/base-fields/properties/repository" },
        "pull_request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "api_url", "html_url", "base_ref", "base_sha", "head_ref", "head_sha", "head_repository"],
          "properties": {
            "number": { "type": "integer", "minimum": 1 },
            "api_url": { "type": "string", "pattern": "^https://api\\.github\\.com/repos/AC-21/sasha-the-land-pirate/pulls/[0-9]+$" },
            "html_url": { "type": "string", "pattern": "^https://github\\.com/AC-21/sasha-the-land-pirate/pull/[0-9]+$" },
            "base_ref": { "const": "main" },
            "base_sha": { "$ref": "#/$defs/git-sha" },
            "head_ref": { "type": "string", "pattern": "^agent/" },
            "head_sha": { "$ref": "#/$defs/git-sha" },
            "head_repository": { "const": "AC-21/sasha-the-land-pirate" }
          }
        },
        "authorization_comment": { "$ref": "#/$defs/comment" },
        "stage1": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "base_sha", "commit_sha", "parent_shas", "tree_oid",
            "full_tree_listing_sha256", "deterministic_patch_sha256",
            "changed_files_manifest_sha256", "changed_files"
          ],
          "properties": {
            "base_sha": { "$ref": "#/$defs/git-sha" },
            "commit_sha": { "$ref": "#/$defs/git-sha" },
            "parent_shas": { "type": "array", "minItems": 1, "maxItems": 1, "items": { "$ref": "#/$defs/git-sha" } },
            "tree_oid": { "$ref": "#/$defs/git-sha" },
            "full_tree_listing_sha256": { "$ref": "#/$defs/sha256" },
            "deterministic_patch_sha256": { "$ref": "#/$defs/sha256" },
            "changed_files_manifest_sha256": { "$ref": "#/$defs/sha256" },
            "changed_files": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/changed-file" } }
          }
        },
        "parsed_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "claim", "contract_sha256", "stage1_commit", "stage1_tree",
            "stage1_patch_sha256", "changed_files_manifest_sha256",
            "receipt_path", "superseded_v1_receipt_id",
            "superseded_v1_receipt_sha256", "superseded_v1_boundary_sha256",
            "supersession_claim", "temporary_nonrequired_check"
          ],
          "properties": {
            "claim": { "const": "AUTHORIZE-WP0002-DELEGATED-LOCAL-UNITY-OPERATOR-SUCCESSOR" },
            "contract_sha256": { "const": "ce03ba29c00cec0235bd90c8044237f3286980ccfd7fe9a685aaa2a1e91e75aa" },
            "stage1_commit": { "$ref": "#/$defs/git-sha" },
            "stage1_tree": { "$ref": "#/$defs/git-sha" },
            "stage1_patch_sha256": { "$ref": "#/$defs/sha256" },
            "changed_files_manifest_sha256": { "$ref": "#/$defs/sha256" },
            "receipt_path": { "const": "docs/foundation-v0.1/ledger/receipts/RR-WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718.json" },
            "superseded_v1_receipt_id": { "const": "RR-WP0002-LOCAL-OPERATOR-20260717" },
            "superseded_v1_receipt_sha256": { "const": "fb1df094bac7c4b944e1438eff4e761963e7076fb58b69f36ef497939eba8b8e" },
            "superseded_v1_boundary_sha256": { "const": "e92e7276dc97478d7412307f43a5f90b60b99256b2a8a7cd5d00626c4f2e0962" },
            "supersession_claim": { "const": "SUPERSEDE-WP0002-LOCAL-OPERATOR-20260717-UNEXECUTED" },
            "temporary_nonrequired_check": { "const": "wp0002-policy" }
          }
        },
        "raw_artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "pull_request", "authorization_comment"],
          "properties": {
            "repository": { "$ref": "#/$defs/artifact-ref" },
            "pull_request": { "$ref": "#/$defs/artifact-ref" },
            "authorization_comment": { "$ref": "#/$defs/artifact-ref" }
          }
        }
      }
    },
    "pre-merge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "transaction_id", "phase", "repository",
        "authority_evidence_sha256", "authorization_comment", "final_pull_request",
        "receipt_materialization", "required_check_runs", "protection_before",
        "protection_during", "raw_artifacts"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718" },
        "phase": { "const": "pre-merge" },
        "repository": { "$ref": "#/$defs/base-fields/properties/repository" },
        "authority_evidence_sha256": { "$ref": "#/$defs/sha256" },
        "authorization_comment": { "$ref": "#/$defs/comment" },
        "final_pull_request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "base_ref", "base_sha", "head_ref", "head_sha", "head_repository", "deterministic_patch_sha256", "github_patch_sha256", "changed_files_manifest_sha256"],
          "properties": {
            "number": { "type": "integer", "minimum": 1 },
            "base_ref": { "const": "main" },
            "base_sha": { "$ref": "#/$defs/git-sha" },
            "head_ref": { "type": "string", "pattern": "^agent/" },
            "head_sha": { "$ref": "#/$defs/git-sha" },
            "head_repository": { "const": "AC-21/sasha-the-land-pirate" },
            "deterministic_patch_sha256": { "$ref": "#/$defs/sha256" },
            "github_patch_sha256": { "$ref": "#/$defs/sha256" },
            "changed_files_manifest_sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "receipt_materialization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commit_sha", "parent_sha", "tree_oid", "receipt_path", "receipt_sha256", "delta_patch_sha256", "delta"],
          "properties": {
            "commit_sha": { "$ref": "#/$defs/git-sha" },
            "parent_sha": { "$ref": "#/$defs/git-sha" },
            "tree_oid": { "$ref": "#/$defs/git-sha" },
            "receipt_path": { "const": "docs/foundation-v0.1/ledger/receipts/RR-WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718.json" },
            "receipt_sha256": { "$ref": "#/$defs/sha256" },
            "delta_patch_sha256": { "$ref": "#/$defs/sha256" },
            "delta": { "type": "array", "minItems": 1, "maxItems": 1, "items": { "$ref": "#/$defs/changed-file" } }
          }
        },
        "required_check_runs": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "app_id", "head_sha", "status", "conclusion"],
            "properties": {
              "name": { "enum": ["validate", "wp0002-core"] },
              "app_id": { "const": 15368 },
              "head_sha": { "$ref": "#/$defs/git-sha" },
              "status": { "const": "completed" },
              "conclusion": { "const": "success" }
            }
          }
        },
        "protection_before": { "$ref": "#/$defs/protection" },
        "protection_during": { "$ref": "#/$defs/protection" },
        "raw_artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pull_request", "github_patch", "check_runs", "protection_before", "protection_during"],
          "properties": {
            "pull_request": { "$ref": "#/$defs/artifact-ref" },
            "github_patch": { "$ref": "#/$defs/artifact-ref" },
            "check_runs": { "$ref": "#/$defs/artifact-ref" },
            "protection_before": { "$ref": "#/$defs/artifact-ref" },
            "protection_during": { "$ref": "#/$defs/artifact-ref" }
          }
        }
      }
    },
    "complete": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "transaction_id", "phase", "repository",
        "pre_merge_evidence_sha256", "merged_pull_request", "merge",
        "protection_after", "completion_comment", "parsed_completion_binding",
        "next_canary_required", "raw_artifacts"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718" },
        "phase": { "const": "complete" },
        "repository": { "$ref": "#/$defs/base-fields/properties/repository" },
        "pre_merge_evidence_sha256": { "$ref": "#/$defs/sha256" },
        "merged_pull_request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "merged", "merged_at", "merge_commit_sha", "base_sha", "head_sha"],
          "properties": {
            "number": { "type": "integer", "minimum": 1 },
            "merged": { "const": true },
            "merged_at": { "$ref": "#/$defs/timestamp" },
            "merge_commit_sha": { "$ref": "#/$defs/git-sha" },
            "base_sha": { "$ref": "#/$defs/git-sha" },
            "head_sha": { "$ref": "#/$defs/git-sha" }
          }
        },
        "merge": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sole_parent_sha", "tree_oid", "final_head_tree_oid", "tree_matches_final_head", "main_contains_merge"],
          "properties": {
            "sole_parent_sha": { "$ref": "#/$defs/git-sha" },
            "tree_oid": { "$ref": "#/$defs/git-sha" },
            "final_head_tree_oid": { "$ref": "#/$defs/git-sha" },
            "tree_matches_final_head": { "const": true },
            "main_contains_merge": { "const": true }
          }
        },
        "protection_after": { "$ref": "#/$defs/protection" },
        "completion_comment": { "$ref": "#/$defs/comment" },
        "parsed_completion_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "claim", "transaction_id", "authority_evidence_sha256",
            "pre_merge_evidence_sha256", "pr_number", "base_sha", "head_sha",
            "final_patch_sha256", "merge_commit_sha", "merge_tree_oid",
            "protection_before_raw_sha256", "protection_during_raw_sha256",
            "protection_after_raw_sha256"
          ],
          "properties": {
            "claim": { "const": "COMPLETE-WP0002-LOCAL-OPERATOR-SUCCESSOR-CONTROL-TRANSACTION" },
            "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718" },
            "authority_evidence_sha256": { "$ref": "#/$defs/sha256" },
            "pre_merge_evidence_sha256": { "$ref": "#/$defs/sha256" },
            "pr_number": { "type": "integer", "minimum": 1 },
            "base_sha": { "$ref": "#/$defs/git-sha" },
            "head_sha": { "$ref": "#/$defs/git-sha" },
            "final_patch_sha256": { "$ref": "#/$defs/sha256" },
            "merge_commit_sha": { "$ref": "#/$defs/git-sha" },
            "merge_tree_oid": { "$ref": "#/$defs/git-sha" },
            "protection_before_raw_sha256": { "$ref": "#/$defs/sha256" },
            "protection_during_raw_sha256": { "$ref": "#/$defs/sha256" },
            "protection_after_raw_sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "next_canary_required": { "const": "first-post-restoration-implementation-pr" },
        "raw_artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pull_request", "main", "protection_after", "authorization_comment", "completion_comment"],
          "properties": {
            "pull_request": { "$ref": "#/$defs/artifact-ref" },
            "main": { "$ref": "#/$defs/artifact-ref" },
            "protection_after": { "$ref": "#/$defs/artifact-ref" },
            "authorization_comment": { "$ref": "#/$defs/artifact-ref" },
            "completion_comment": { "$ref": "#/$defs/artifact-ref" }
          }
        }
      }
    }
  }
}

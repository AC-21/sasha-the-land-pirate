{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/sasha-atomic-land-pirate/scenario-artifact.schema.json",
  "title": "Materialized scenario artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_kind", "semantic_id", "scenario_id", "scenario_revision"],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact_kind": { "enum": ["starting-state", "content-set", "input-script"] },
    "semantic_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "scenario_id": { "type": "string", "pattern": "^SCN_[A-Z0-9_]+$" },
    "scenario_revision": { "type": "integer", "minimum": 1 },
    "world_seed": { "type": "string", "pattern": "^[0-9]+$" },
    "starting_tick": { "type": "string", "pattern": "^[0-9]+$" },
    "canonicalization": { "type": "string", "minLength": 1 },
    "canonical_entities": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "canonical_state_records": { "type": "array", "items": { "$ref": "#/$defs/stateRecord" } },
    "case_states": { "type": "array", "items": { "$ref": "#/$defs/caseState" } },
    "definitions": { "type": "array", "items": { "$ref": "#/$defs/contentDefinition" } },
    "render_workload": { "type": "object" },
    "tick_rate_hz": { "type": "integer", "minimum": 1, "maximum": 120 },
    "warmup_ticks": { "type": "integer", "minimum": 0 },
    "duration_ticks": { "type": "integer", "minimum": 0 },
    "normative_execution": { "$ref": "#/$defs/execution" },
    "target_bindings_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "target_bindings": { "type": "array", "items": { "$ref": "#/$defs/targetBinding" } },
    "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
    "case_events": { "type": "array", "items": { "$ref": "#/$defs/caseEvents" } },
    "oracle_observations": { "type": "array", "items": { "$ref": "#/$defs/observation" } },
    "camera_path": { "type": "object" }
  },
  "oneOf": [
    {
      "properties": { "artifact_kind": { "const": "starting-state" } },
      "required": ["world_seed", "starting_tick", "canonicalization", "canonical_entities", "canonical_state_records", "case_states"]
    },
    {
      "properties": { "artifact_kind": { "const": "content-set" } },
      "required": ["canonicalization", "definitions"]
    },
    {
      "properties": { "artifact_kind": { "const": "input-script" } },
      "required": ["tick_rate_hz", "warmup_ticks", "duration_ticks", "normative_execution", "target_bindings_sha256", "target_bindings", "events", "case_events", "oracle_observations"]
    }
  ],
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "ordinal", "value"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["settlement", "building", "household", "specialist", "robot", "vehicle", "faction", "crisis", "expedition"] },
        "ordinal": { "type": "integer", "minimum": 1 },
        "value": { "type": "object", "minProperties": 3 }
      }
    },
    "stateRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "domain", "ordinal", "version", "value"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "domain": { "enum": ["world", "settlement", "population", "logistics", "vehicle", "expedition", "faction", "crisis", "audit", "save"] },
        "ordinal": { "type": "integer", "minimum": 1 },
        "version": { "const": 1 },
        "value": { "type": "object", "minProperties": 3 }
      }
    },
    "caseState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "canonical_entities", "canonical_state_records", "ablation_contract"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "canonical_entities": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
        "canonical_state_records": { "type": "array", "items": { "$ref": "#/$defs/stateRecord" } },
        "ablation_contract": { "type": "object" }
      }
    },
    "contentDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "version", "tags", "enabled", "contract"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["resource", "recipe", "building", "capability", "route", "faction-rule", "save-section", "presentation-binding"] },
        "version": { "const": 1 },
        "tags": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "enabled": { "type": "boolean" },
        "contract": { "type": "object", "minProperties": 2 }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ordering", "fixed_tick_rule", "case_isolation", "unknown_command_rule", "integer_rule", "autonomous_tick_rule", "target_resolution_rule", "unresolved_target_rule", "target_binding_hash_rule"],
      "properties": {
        "ordering": { "type": "string", "minLength": 1 },
        "fixed_tick_rule": { "type": "string", "minLength": 1 },
        "case_isolation": { "type": "string", "minLength": 1 },
        "unknown_command_rule": { "type": "string", "minLength": 1 },
        "integer_rule": { "type": "string", "minLength": 1 },
        "autonomous_tick_rule": { "type": "string", "minLength": 1 },
        "target_resolution_rule": { "type": "string", "minLength": 1 },
        "unresolved_target_rule": { "type": "string", "minLength": 1 },
        "target_binding_hash_rule": { "type": "string", "minLength": 1 }
      }
    },
    "targetBinding": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["logical_target_id", "binding_kind", "resolved_id", "case_resolutions"],
          "properties": {
            "logical_target_id": { "type": "string", "minLength": 1 },
            "binding_kind": { "enum": ["canonical-entity", "canonical-state-record", "content-definition"] },
            "resolved_id": { "type": "string", "minLength": 1 },
            "case_resolutions": { "type": "array", "items": { "$ref": "#/$defs/caseResolution" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["logical_target_id", "binding_kind", "selector_kind", "selector_value"],
          "properties": {
            "logical_target_id": { "type": "string", "minLength": 1 },
            "binding_kind": { "const": "scenario-selector" },
            "selector_kind": { "enum": ["scenario-root", "save-subsystem", "clock-subsystem", "oracle-surface"] },
            "selector_value": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "caseResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "resolved_id"],
      "properties": {
        "case_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "resolved_id": { "type": "string", "minLength": 1 }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "tick", "kind", "payload"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "tick": { "type": "integer", "minimum": 0 },
        "kind": { "enum": ["scripted_commands", "keyboard_events", "controller_events", "pointer_events", "fault_injections"] },
        "payload": { "type": "object", "minProperties": 2 }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "tick", "subject", "selector", "operator", "expected_source", "oracle_id"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "tick": { "type": "integer", "minimum": 0 },
        "subject": { "type": "string", "minLength": 1 },
        "selector": { "type": "string", "minLength": 1 },
        "operator": { "enum": ["equal", "less-than", "less-or-equal", "greater-or-equal", "matches-reference"] },
        "expected_source": { "const": "scenario-definition" },
        "oracle_id": { "type": "string", "pattern": "^ORC_[A-Z0-9_]+$" }
      }
    },
    "caseEvents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "events", "oracle_observations"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
        "oracle_observations": { "type": "array", "items": { "$ref": "#/$defs/observation" } }
      }
    }
  }
}

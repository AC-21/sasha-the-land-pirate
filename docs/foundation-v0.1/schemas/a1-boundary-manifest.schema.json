{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/wasteland-game/a1-boundary-manifest.schema.json",
  "title": "Creator-attested A1 quarantine boundary",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "absoluteRuntimeRoot": {
      "type": "string",
      "pattern": "^/(?:[^/]+/)*[^/]+$"
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "clientEnvironmentGuard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "CODEX_HOME",
        "XDG_CONFIG_HOME",
        "XDG_CACHE_HOME",
        "XDG_DATA_HOME",
        "GIT_CONFIG_NOSYSTEM",
        "GIT_CONFIG_GLOBAL",
        "GIT_TERMINAL_PROMPT",
        "absent_variables"
      ],
      "properties": {
        "CODEX_HOME": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "XDG_CONFIG_HOME": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "XDG_CACHE_HOME": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "XDG_DATA_HOME": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "GIT_CONFIG_NOSYSTEM": { "const": "1" },
        "GIT_CONFIG_GLOBAL": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "GIT_TERMINAL_PROMPT": { "const": "0" },
        "absent_variables": {
          "const": [
            "AWS_ACCESS_KEY_ID",
            "AWS_SECRET_ACCESS_KEY",
            "AWS_SESSION_TOKEN",
            "GH_TOKEN",
            "GITHUB_TOKEN",
            "GIT_ASKPASS",
            "SSH_AUTH_SOCK",
            "VERCEL_TOKEN"
          ]
        }
      }
    },
    "codeIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_scope",
        "identifier",
        "team_identifier",
        "cdhash",
        "designated_requirement_sha256",
        "authorities_sha256"
      ],
      "properties": {
        "verification_scope": { "const": "codesign-strict-component" },
        "identifier": { "type": "string", "minLength": 1 },
        "team_identifier": {
          "type": "string",
          "pattern": "^[A-Z0-9]{10}$"
        },
        "cdhash": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "designated_requirement_sha256": { "$ref": "#/$defs/sha256" },
        "authorities_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "packet_id",
    "packet_contract_sha256",
    "created_at",
    "attested_by",
    "attestation_receipt_id",
    "repository",
    "reservation",
    "approved_toolchain",
    "approved_environment",
    "runtime_boundary",
    "foundation_binding",
    "protection_boundary",
    "credential_boundary",
    "manual_import_boundary",
    "local_observation_exceptions"
  ],
  "properties": {
    "schema_version": { "const": 4 },
    "manifest_id": { "type": "string", "pattern": "^A1B-WP-[0-9]{4}-[A-Z0-9-]+$" },
    "packet_id": { "type": "string", "pattern": "^WP-[0-9]{4}$" },
    "packet_contract_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "attested_by": { "type": "string", "minLength": 1 },
    "attestation_receipt_id": { "type": "string", "pattern": "^RR-[A-Z0-9-]+$" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolver_type",
        "repository_root",
        "absolute_root",
        "trusted_root",
        "trusted_remote_url",
        "base_commit",
        "git_directory",
        "git_common_directory",
        "detached_head",
        "remote_count",
        "alternates_present"
      ],
      "properties": {
        "resolver_type": { "const": "local-git" },
        "repository_root": { "const": "." },
        "absolute_root": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "trusted_root": {
          "const": "/Users/sasha/Documents/Codex/sasha-the-land-pirate"
        },
        "trusted_remote_url": {
          "const": "https://github.com/AC-21/sasha-the-land-pirate"
        },
        "base_commit": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
        "git_directory": { "const": ".git" },
        "git_common_directory": { "const": ".git" },
        "detached_head": { "const": true },
        "remote_count": { "const": 0 },
        "alternates_present": { "const": false }
      }
    },
    "reservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id", "fencing_token", "expires_at", "paths", "domains"],
      "properties": {
        "lease_id": { "type": "string", "minLength": 1 },
        "fencing_token": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "format": "date-time" },
        "paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "domains": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "approved_toolchain": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "source", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "approved_environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "os_version",
        "architecture",
        "hardware_id",
        "sandbox_profile",
        "sandbox_profile_sha256",
        "network_policy",
        "network_policy_sha256"
      ],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "os_version": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "hardware_id": { "type": "string", "minLength": 1 },
        "sandbox_profile": { "type": "string", "minLength": 1 },
        "sandbox_profile_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "network_policy": { "type": "string", "minLength": 1 },
        "network_policy_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "runtime_boundary": {
      "description": "Creator-attested disposable process namespace for mutable tool, relay, licensing, cache, and log state outside the repository.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isolation_mode",
        "instance_id",
        "principal_id",
        "principal_uid",
        "boot_session_sha256",
        "ephemeral_home_root",
        "private_temp_root",
        "environment_bindings",
        "client_environment_guard",
        "ambient_host_home_root",
        "ambient_shared_temp_roots",
        "denied_ambient_write_roots",
        "ambient_shared_temp_write_exceptions",
        "ambient_host_home_write_denied",
        "ambient_shared_temp_write_denied",
        "symlink_escape_forbidden",
        "runtime_roots_symlink_free",
        "runtime_roots_importable",
        "destroy_on_close"
      ],
      "properties": {
        "isolation_mode": {
          "enum": [
            "dedicated-ephemeral-os-user",
            "equivalent-os-sandbox"
          ]
        },
        "instance_id": { "type": "string", "minLength": 1 },
        "principal_id": { "type": "string", "minLength": 1 },
        "principal_uid": { "type": "integer", "minimum": 1 },
        "boot_session_sha256": { "$ref": "#/$defs/sha256" },
        "ephemeral_home_root": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "private_temp_root": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "environment_bindings": {
          "type": "object",
          "additionalProperties": false,
          "required": ["HOME", "TMPDIR", "TMP", "TEMP"],
          "properties": {
            "HOME": { "$ref": "#/$defs/absoluteRuntimeRoot" },
            "TMPDIR": { "$ref": "#/$defs/absoluteRuntimeRoot" },
            "TMP": { "$ref": "#/$defs/absoluteRuntimeRoot" },
            "TEMP": { "$ref": "#/$defs/absoluteRuntimeRoot" }
          }
        },
        "client_environment_guard": {
          "$ref": "#/$defs/clientEnvironmentGuard"
        },
        "ambient_host_home_root": { "$ref": "#/$defs/absoluteRuntimeRoot" },
        "ambient_shared_temp_roots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/absoluteRuntimeRoot" }
        },
        "denied_ambient_write_roots": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/absoluteRuntimeRoot" }
        },
        "ambient_shared_temp_write_exceptions": {
          "description": "Exact creator-attested paths under otherwise denied shared-temp roots that the approved toolchain must create. Empty unless a packet-specific validator binds every exception.",
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/absoluteRuntimeRoot" }
        },
        "ambient_host_home_write_denied": { "const": true },
        "ambient_shared_temp_write_denied": {
          "description": "Shared-temp writes are default-denied except for exact paths in ambient_shared_temp_write_exceptions.",
          "const": true
        },
        "symlink_escape_forbidden": { "const": true },
        "runtime_roots_symlink_free": { "const": true },
        "runtime_roots_importable": { "const": false },
        "destroy_on_close": { "const": true }
      }
    },
    "foundation_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constitution_path", "constitution_sha256", "decision_ledger_path", "decision_ledger_sha256", "last_creator_receipt_id"],
      "properties": {
        "constitution_path": { "const": "00-GAME-CONSTITUTION.md" },
        "constitution_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "decision_ledger_path": { "const": "ledger/decisions.jsonl" },
        "decision_ledger_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "last_creator_receipt_id": { "type": "string", "pattern": "^RR-[A-Z0-9-]+$" }
      }
    },
    "protection_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protected_paths",
        "writable_paths",
        "ephemeral_scratch_paths",
        "scratch_destroy_on_close",
        "foundation_read_only"
      ],
      "properties": {
        "protected_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "writable_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "ephemeral_scratch_paths": {
          "description": "Exact non-output scratch roots needed by the approved toolchain. They are outside the packet reservation, cannot be imported, and must be repository-ignored.",
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "scratch_destroy_on_close": { "const": true },
        "foundation_read_only": { "const": true }
      }
    },
    "credential_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved_credential_ids", "denied_capabilities"],
      "properties": {
        "approved_credential_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "denied_capabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "manual_import_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "agent_can_merge", "agent_can_release", "agent_can_accept_evidence", "creator_review_required"],
      "properties": {
        "mode": { "const": "creator-operated-import-or-reject" },
        "agent_can_merge": { "const": false },
        "agent_can_release": { "const": false },
        "agent_can_accept_evidence": { "const": false },
        "creator_review_required": { "const": true }
      }
    },
    "project_seed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "project_root",
        "base_commit",
        "git_tree_sha256",
        "evidence",
        "creator_attested_no_implementation"
      ],
      "properties": {
        "mode": { "const": "creator-created-protected-base" },
        "project_root": { "const": "Game" },
        "base_commit": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
        "git_tree_sha256": { "$ref": "#/$defs/sha256" },
        "evidence": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/project-seed.json" }
              }
            }
          ]
        },
        "creator_attested_no_implementation": { "const": true }
      }
    },
    "wp0001_toolchain_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hub_version",
        "editor_version",
        "editor_changeset",
        "editor_architecture",
        "mac_il2cpp_installed",
        "mac_il2cpp_editor_version",
        "xcode_version",
        "rosetta_installed",
        "dotnet_sdk_version",
        "assistant_package_version",
        "resolved_urp_version",
        "resolved_test_framework_version",
        "mono_iteration_authorized",
        "il2cpp_arm64_acceptance"
      ],
      "properties": {
        "hub_version": { "const": "3.19.5" },
        "editor_version": { "const": "6000.3.19f1" },
        "editor_changeset": { "const": "7689f4515d75" },
        "editor_architecture": { "const": "arm64" },
        "mac_il2cpp_installed": { "const": true },
        "mac_il2cpp_editor_version": { "const": "6000.3.19f1" },
        "xcode_version": { "const": "26.3" },
        "rosetta_installed": { "const": true },
        "dotnet_sdk_version": { "const": "10.0.301" },
        "assistant_package_version": { "const": "2.14.0-pre.1" },
        "resolved_urp_version": {
          "type": "string",
          "pattern": "^17\\.3(?:\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?)?$"
        },
        "resolved_test_framework_version": {
          "type": "string",
          "pattern": "^1\\.6(?:\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?)?$"
        },
        "mono_iteration_authorized": { "const": true },
        "il2cpp_arm64_acceptance": { "const": true }
      }
    },
    "activation_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest",
        "toolchain",
        "quarantine",
        "route",
        "activation_session",
        "deviations",
        "sandbox_policy",
        "network_policy"
      ],
      "properties": {
        "manifest": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/evidence-manifest.json" }
              }
            }
          ]
        },
        "toolchain": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/toolchain.json" }
              }
            }
          ]
        },
        "quarantine": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/quarantine.json" }
              }
            }
          ]
        },
        "route": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/mcp-route.json" }
              }
            }
          ]
        },
        "activation_session": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/activation-session.json" }
              }
            }
          ]
        },
        "deviations": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/deviations.json" }
              }
            }
          ]
        },
        "sandbox_policy": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/sandbox.policy" }
              }
            }
          ]
        },
        "network_policy": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": { "const": "docs/evidence/WP-0001/a1-activation/network.policy" }
              }
            }
          ]
        }
      }
    },
    "raw_capture_collectors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "network",
        "policy_attachment",
        "authority_claim"
      ],
      "properties": {
        "protocol": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": {
                  "pattern": "^docs/foundation-v0\\.1/tools/[a-z0-9_]+\\.py$"
                }
              }
            }
          ]
        },
        "network": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": {
                  "pattern": "^docs/foundation-v0\\.1/tools/[a-z0-9_]+\\.py$"
                }
              }
            }
          ]
        },
        "policy_attachment": {
          "allOf": [
            { "$ref": "#/$defs/evidenceRef" },
            {
              "properties": {
                "path": {
                  "const": "docs/foundation-v0.1/tools/capture_wp0001_policy_attachment.py"
                }
              }
            }
          ]
        },
        "authority_claim": {
          "const": "AUTHORIZE-WP0001-RAW-COLLECTORS"
        }
      }
    },
    "unity_mcp_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "code_identity_authority_claim",
        "client",
        "relay",
        "bridge",
        "entitlement",
        "project_identity",
        "codex_policy",
        "process_observation",
        "connection",
        "handshake",
        "activation_session",
        "controls"
      ],
      "properties": {
        "route": { "const": "UNITY-MCP-EXTERNAL" },
        "code_identity_authority_claim": {
          "const": "AUTHORIZE-WP0001-CODE-IDENTITIES"
        },
        "client": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "version",
            "publisher",
            "signing_identity",
            "pid",
            "started_at",
            "process_birth_id_sha256",
            "environment_sha256",
            "environment_names_sha256",
            "server_inventory_sha256",
            "principal_uid",
            "cwd",
            "arguments"
          ],
          "properties": {
            "path": { "$ref": "#/$defs/absoluteRuntimeRoot" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "version": { "type": "string", "minLength": 1 },
            "publisher": { "type": "string", "minLength": 1 },
            "signing_identity": { "$ref": "#/$defs/codeIdentity" },
            "pid": { "type": "integer", "minimum": 1 },
            "started_at": { "type": "string", "format": "date-time" },
            "process_birth_id_sha256": { "$ref": "#/$defs/sha256" },
            "environment_sha256": { "$ref": "#/$defs/sha256" },
            "environment_names_sha256": { "$ref": "#/$defs/sha256" },
            "server_inventory_sha256": { "$ref": "#/$defs/sha256" },
            "principal_uid": { "type": "integer", "minimum": 1 },
            "cwd": { "$ref": "#/$defs/absoluteRuntimeRoot" },
            "arguments": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        "relay": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "package_copy_path",
            "package_copy_sha256",
            "version",
            "signing_identity",
            "pid",
            "started_at",
            "process_birth_id_sha256",
            "environment_names_sha256",
            "parent_pid",
            "principal_uid",
            "arguments"
          ],
          "properties": {
            "path": { "$ref": "#/$defs/absoluteRuntimeRoot" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "package_copy_path": { "$ref": "#/$defs/absoluteRuntimeRoot" },
            "package_copy_sha256": { "$ref": "#/$defs/sha256" },
            "version": { "type": "string", "minLength": 1 },
            "signing_identity": { "$ref": "#/$defs/codeIdentity" },
            "pid": { "type": "integer", "minimum": 1 },
            "started_at": { "type": "string", "format": "date-time" },
            "process_birth_id_sha256": { "$ref": "#/$defs/sha256" },
            "environment_names_sha256": { "$ref": "#/$defs/sha256" },
            "parent_pid": { "type": "integer", "minimum": 1 },
            "principal_uid": { "type": "integer", "minimum": 1 },
            "arguments": {
              "type": "array",
              "minItems": 5,
              "items": { "type": "string" }
            }
          }
        },
        "bridge": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "editor_pid",
            "started_at",
            "process_birth_id_sha256",
            "environment_names_sha256",
            "editor_path",
            "editor_sha256",
            "editor_version",
            "editor_changeset",
            "signing_identity",
            "principal_uid",
            "cwd",
            "arguments",
            "project_path",
            "connection_file",
            "connection_file_sha256",
            "protocol_version",
            "discovery_connection_type",
            "physical_transport",
            "endpoint",
            "endpoint_owner_uid",
            "endpoint_mode",
            "shared_temp_exception",
            "discovery_record"
          ],
          "properties": {
            "editor_pid": { "type": "integer", "minimum": 1 },
            "started_at": { "type": "string", "format": "date-time" },
            "process_birth_id_sha256": { "$ref": "#/$defs/sha256" },
            "environment_names_sha256": { "$ref": "#/$defs/sha256" },
            "editor_path": { "$ref": "#/$defs/absoluteRuntimeRoot" },
            "editor_sha256": { "$ref": "#/$defs/sha256" },

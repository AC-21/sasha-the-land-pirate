{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/wasteland-game/ratification-receipt.schema.json",
  "title": "Creator ratification receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "issued_at",
    "issued_by",
    "issuer_role",
    "receipt_kind",
    "artifact_resolver",
    "source_reference",
    "subject_ids",
    "subject_claims",
    "approval_text_sha256",
    "accepted_commit",
    "artifact_sha256",
    "subject_contract_sha256",
    "subject_event_sha256",
    "foundation_binding",
    "signature_reference",
    "sealed"
  ],
  "properties": {
    "receipt_id": { "type": "string", "pattern": "^RR-[A-Z0-9-]+$" },
    "issued_at": { "type": "string", "format": "date-time" },
    "issued_by": { "type": "string", "minLength": 1 },
    "issuer_role": { "enum": ["creator", "trusted-integrator", "trusted-gatekeeper", "external-authority"] },
    "receipt_kind": { "enum": ["creator-source-capture", "creator-authorization", "decision-ratification", "packet-acceptance", "packet-activation", "packet-completion", "release-approval", "external-protected"] },
    "artifact_resolver": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": { "type": { "const": "local-git-tree" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "resolver_reference"],
          "properties": {
            "type": { "const": "external-protected" },
            "resolver_reference": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "source_reference": { "type": "string", "minLength": 1 },
    "subject_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "subject_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["subject_id", "claims"],
        "properties": {
          "subject_id": { "type": "string", "minLength": 1 },
          "claims": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z0-9+_-]+$" } }
        }
      }
    },
    "approval_text_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "accepted_commit": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40,64}$" },
    "artifact_sha256": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" } },
    "subject_contract_sha256": {
      "type": "object",
      "propertyNames": { "type": "string", "minLength": 1 },
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "subject_event_sha256": {
      "type": "object",
      "propertyNames": { "type": "string", "minLength": 1 },
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "foundation_binding": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["constitution_sha256", "decision_ledger_sha256", "last_creator_receipt_id"],
          "properties": {
            "constitution_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "decision_ledger_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "last_creator_receipt_id": { "type": "string", "pattern": "^RR-[A-Z0-9-]+$" }
          }
        }
      ]
    },
    "materialization_authority_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim",
        "supersession_claim",
        "amendment_id",
        "receipt_id",
        "pr_number",
        "packet_contract_sha256",
        "previous_boundary_sha256",
        "repository_remote",
        "predecessor_repository_root",
        "successor_repository_root",
        "predecessor_project_path",
        "successor_project_path",
        "stage1_base",
        "stage1_commit",
        "stage1_tree",
        "stage1_patch_sha256",
        "changed_files_manifest_sha256",
        "changed_paths",
        "receipt_path",
        "temporary_nonrequired_check",
        "retained_required_checks",
        "restored_required_checks"
      ],
      "properties": {
        "claim": { "type": "string", "pattern": "^[A-Z0-9+_-]+$" },
        "supersession_claim": { "type": "string", "pattern": "^[A-Z0-9+_-]+$" },
        "amendment_id": { "type": "string", "minLength": 1 },
        "receipt_id": { "type": "string", "pattern": "^RR-[A-Z0-9-]+$" },
        "pr_number": { "type": "integer", "minimum": 1 },
        "packet_contract_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "previous_boundary_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "repository_remote": { "type": "string", "minLength": 1 },
        "predecessor_repository_root": { "type": "string", "minLength": 1 },
        "successor_repository_root": { "type": "string", "minLength": 1 },
        "predecessor_project_path": { "type": "string", "minLength": 1 },
        "successor_project_path": { "type": "string", "minLength": 1 },
        "stage1_base": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "stage1_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "stage1_tree": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "stage1_patch_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "changed_files_manifest_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "changed_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "receipt_path": { "type": "string", "minLength": 1 },
        "temporary_nonrequired_check": { "type": "string", "minLength": 1 },
        "retained_required_checks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "restored_required_checks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "signature_reference": { "type": ["string", "null"] },
    "sealed": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": { "properties": { "sealed": { "const": true } } },
      "then": {
        "properties": {
          "accepted_commit": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
          "signature_reference": { "type": "string", "minLength": 1 }
        }
      }
    }
  ]
}

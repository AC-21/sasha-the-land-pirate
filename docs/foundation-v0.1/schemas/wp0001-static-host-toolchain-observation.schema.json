{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/wasteland-game/wp0001-static-host-toolchain-observation.schema.json",
  "title": "WP-0001 A0 static host and toolchain observation",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "gitObject": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "location",
        "sha256",
        "observation"
      ],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "observation": { "type": "string", "minLength": 1 }
      }
    },
    "requirementObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "required",
        "observed",
        "status",
        "evidence",
        "limitations"
      ],
      "properties": {
        "id": {
          "enum": [
            "UNITY-HUB",
            "UNITY-EDITOR",
            "MAC-BUILD-SUPPORT-IL2CPP",
            "XCODE",
            "DOTNET-SDK",
            "ROSETTA-2",
            "UNITY-AI-ASSISTANT",
            "URP",
            "UNITY-TEST-FRAMEWORK"
          ]
        },
        "required": { "type": "string", "minLength": 1 },
        "observed": { "type": ["string", "null"] },
        "status": {
          "enum": [
            "matched",
            "mismatch",
            "missing",
            "unverified",
            "unsafe"
          ]
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceItem" }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fileReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_kind",
    "observation_id",
    "packet_id",
    "packet_contract_sha256",
    "base_commit",
    "captured_at",
    "collector",
    "authority",
    "collection",
    "host",
    "toolchain",
    "package_graph",
    "profile_status",
    "blocking_requirement_ids",
    "evidence_limitations"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "document_kind": {
      "const": "wp0001-static-host-toolchain-observation"
    },
    "observation_id": {
      "type": "string",
      "pattern": "^OBS-WP0001-STATIC-[0-9]{14}Z$"
    },
    "packet_id": { "const": "WP-0001" },
    "packet_contract_sha256": {
      "const": "eed333603affe6aa1dd2b16b26ae702d9f561cc653fa319da02abfe008faeda3"
    },
    "base_commit": { "$ref": "#/$defs/gitObject" },
    "captured_at": { "type": "string", "format": "date-time" },
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "source_path",
        "source_sha256"
      ],
      "properties": {
        "name": { "const": "inspect_wp0001_toolchain_static" },
        "version": { "const": "wp0001-static-toolchain-v1" },
        "source_path": { "type": "string", "minLength": 1 },
        "source_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_autonomy",
        "activation_authority",
        "activation_evidence_eligible",
        "a1_activation_receipt_id"
      ],
      "properties": {
        "current_autonomy": { "const": "A0" },
        "activation_authority": { "const": false },
        "activation_evidence_eligible": { "const": false },
        "a1_activation_receipt_id": { "type": "null" }
      }
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "status",
        "contains_secret_values",
        "unity_family_processes_invoked",
        "external_processes_invoked",
        "network_accessed"
      ],
      "properties": {
        "mode": { "const": "static-filesystem-only" },
        "status": { "enum": ["complete", "partial", "failed"] },
        "contains_secret_values": { "const": false },
        "unity_family_processes_invoked": { "const": false },
        "external_processes_invoked": { "const": false },
        "network_accessed": { "const": false }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "os_version", "architecture"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "os_version": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 }
      }
    },
    "toolchain": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "prefixItems": [
        {
          "allOf": [
            { "$ref": "#/$defs/requirementObservation" },
            { "properties": { "id": { "const": "UNITY-HUB" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/requirementObservation" },
            { "properties": { "id": { "const": "UNITY-EDITOR" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/requirementObservation" },
            {
              "properties": {
                "id": { "const": "MAC-BUILD-SUPPORT-IL2CPP" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/requirementObservation" },
            { "properties": { "id": { "const": "XCODE" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/requirementObservation" },
            { "properties": { "id": { "const": "DOTNET-SDK" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/requirementObservation" },
            { "properties": { "id": { "const": "ROSETTA-2" } } }
          ]
        }
      ],
      "items": false
    },
    "package_graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_root",
        "manifest",
        "lock",
        "graph_status",
        "canonical_graph_sha256",
        "requirements",
        "limitations"
      ],
      "properties": {
        "project_root": { "type": "string", "minLength": 1 },
        "manifest": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "lock": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "graph_status": {
          "enum": ["matched", "mismatch", "missing", "unverified", "unsafe"]
        },
        "canonical_graph_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "requirements": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {
              "allOf": [
                { "$ref": "#/$defs/requirementObservation" },
                {
                  "properties": {
                    "id": { "const": "UNITY-AI-ASSISTANT" }
                  }
                }
              ]
            },
            {
              "allOf": [
                { "$ref": "#/$defs/requirementObservation" },
                { "properties": { "id": { "const": "URP" } } }
              ]
            },
            {
              "allOf": [
                { "$ref": "#/$defs/requirementObservation" },
                {
                  "properties": {
                    "id": { "const": "UNITY-TEST-FRAMEWORK" }
                  }
                }
              ]
            }
          ],
          "items": false
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "profile_status": {
      "enum": ["matched", "blocked", "indeterminate"]
    },
    "blocking_requirement_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "UNITY-HUB",
          "UNITY-EDITOR",
          "MAC-BUILD-SUPPORT-IL2CPP",
          "XCODE",
          "DOTNET-SDK",
          "ROSETTA-2",
          "UNITY-AI-ASSISTANT",
          "URP",
          "UNITY-TEST-FRAMEWORK"
        ]
      }
    },
    "evidence_limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ac-21.github.io/sasha-the-land-pirate/schemas/wp0002-local-operator-recovery-transaction-evidence.schema.json",
  "title": "WP-0002 mixed-reader recovery transaction evidence",
  "oneOf": [
    { "$ref": "#/$defs/authority" },
    { "$ref": "#/$defs/pre-merge" },
    { "$ref": "#/$defs/complete" }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git-sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full_name", "id", "owner_login", "owner_id"],
      "properties": {
        "full_name": { "const": "AC-21/sasha-the-land-pirate" },
        "id": { "type": "integer", "minimum": 1 },
        "owner_login": { "const": "AC-21" },
        "owner_id": { "type": "integer", "minimum": 1 }
      }
    },
    "base": {
      "type": "object",
      "required": ["schema_version", "transaction_id", "phase", "repository"],
      "properties": {
        "schema_version": { "const": 1 },
        "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-CLOSURE-RECOVERY-20260718" },
        "phase": { "enum": ["authority", "pre-merge", "complete"] },
        "repository": { "$ref": "#/$defs/repository" }
      }
    },
    "authority": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version", "transaction_id", "phase", "repository",
            "pull_request", "authorization_comment", "stage1",
            "parsed_binding", "raw_artifacts"
          ],
          "properties": {
            "schema_version": { "const": 1 },
            "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-CLOSURE-RECOVERY-20260718" },
            "phase": { "const": "authority" },
            "repository": { "$ref": "#/$defs/repository" },
            "pull_request": { "type": "object" },
            "authorization_comment": { "type": "object" },
            "stage1": {
              "type": "object",
              "required": ["base_sha", "commit_sha", "tree_oid", "changed_files"],
              "properties": {
                "base_sha": { "const": "166d53698d013c605c7bee749368193dc2834644" },
                "commit_sha": { "$ref": "#/$defs/git-sha" },
                "tree_oid": { "$ref": "#/$defs/git-sha" },
                "changed_files": { "type": "array", "minItems": 1 }
              }
            },
            "parsed_binding": {
              "type": "object",
              "required": [
                "claim", "contract_sha256", "predecessor_transaction_id",
                "predecessor_receipt_id", "predecessor_receipt_sha256",
                "predecessor_boundary_sha256", "supersession_claim",
                "receipt_path", "temporary_nonrequired_check"
              ],
              "properties": {
                "claim": { "const": "AUTHORIZE-WP0002-LOCAL-OPERATOR-MIXED-READER-RECOVERY" },
                "contract_sha256": { "const": "ce03ba29c00cec0235bd90c8044237f3286980ccfd7fe9a685aaa2a1e91e75aa" },
                "predecessor_transaction_id": { "const": "WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718" },
                "predecessor_receipt_id": { "const": "RR-WP0002-LOCAL-OPERATOR-SUCCESSOR-20260718" },
                "predecessor_receipt_sha256": { "const": "b82fc75e9f359f23a976ed3e073fddcf92a1b6d632b5d9e1d5115e70e43904ce" },
                "predecessor_boundary_sha256": { "const": "1f9bbce5906b720ba6aff92143584b9c668731c8c11f71fe6d967cff26e358a2" },
                "supersession_claim": { "const": "SUPERSEDE-WP0002-LOCAL-OPERATOR-SUCCESSOR-CLOSURE-VERIFIER-V2-UNEXECUTED" },
                "receipt_path": { "const": "docs/foundation-v0.1/ledger/receipts/RR-WP0002-LOCAL-OPERATOR-RECOVERY-20260718.json" },
                "temporary_nonrequired_check": { "const": "wp0002-policy" }
              }
            },
            "raw_artifacts": { "type": "object" }
          }
        }
      ]
    },
    "pre-merge": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version", "transaction_id", "phase", "repository",
            "authority_evidence_sha256", "authorization_comment",
            "final_pull_request", "receipt_materialization",
            "required_check_runs", "protection_before", "protection_during",
            "raw_artifacts"
          ],
          "properties": {
            "schema_version": { "const": 1 },
            "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-CLOSURE-RECOVERY-20260718" },
            "phase": { "const": "pre-merge" },
            "repository": { "$ref": "#/$defs/repository" },
            "authority_evidence_sha256": { "$ref": "#/$defs/sha256" },
            "authorization_comment": { "type": "object" },
            "final_pull_request": { "type": "object" },
            "receipt_materialization": {
              "type": "object",
              "properties": {
                "receipt_path": { "const": "docs/foundation-v0.1/ledger/receipts/RR-WP0002-LOCAL-OPERATOR-RECOVERY-20260718.json" }
              }
            },
            "required_check_runs": { "type": "array", "minItems": 2, "maxItems": 2 },
            "protection_before": { "type": "object" },
            "protection_during": { "type": "object" },
            "raw_artifacts": { "type": "object" }
          }
        }
      ]
    },
    "complete": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version", "transaction_id", "phase", "repository",
            "pre_merge_evidence_sha256", "merged_pull_request", "merge",
            "protection_after", "completion_comment",
            "parsed_completion_binding", "next_canary_required",
            "raw_artifacts"
          ],
          "properties": {
            "schema_version": { "const": 1 },
            "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-CLOSURE-RECOVERY-20260718" },
            "phase": { "const": "complete" },
            "repository": { "$ref": "#/$defs/repository" },
            "pre_merge_evidence_sha256": { "$ref": "#/$defs/sha256" },
            "merged_pull_request": { "type": "object" },
            "merge": { "type": "object" },
            "protection_after": { "type": "object" },
            "completion_comment": { "type": "object" },
            "parsed_completion_binding": {
              "type": "object",
              "properties": {
                "claim": { "const": "COMPLETE-WP0002-LOCAL-OPERATOR-RECOVERY-CONTROL-TRANSACTION" },
                "transaction_id": { "const": "WP0002-LOCAL-OPERATOR-CLOSURE-RECOVERY-20260718" }
              }
            },
            "next_canary_required": { "const": "first-post-restoration-implementation-pr" },
            "raw_artifacts": { "type": "object" }
          }
        }
      ]
    }
  }
}
